    "This will delete all local files for this repository. This cannot be undone.": {
      "comment": "Alert message warning that removing a repository is permanent",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will delete all local files for this repository. This cannot be undone."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى حذف جميع الملفات المحلية لهذا المستودع. لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette sletter alle lokale filer for dette repository. Dette kan ikke fortrydes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle lokalen Dateien dieses Repositories werden gelöscht. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se eliminarán todos los archivos locales de este repositorio. Esta acción no se puede deshacer."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä poistaa kaikki tämän tietovaraston paikalliset tiedostot. Tätä ei voi kumota."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous les fichiers locaux de ce dépôt seront supprimés. Cette action est irréversible."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "פעולה זו תמחק את כל הקבצים המקומיים של מאגר זה. לא ניתן לבטל פעולה זו."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इससे इस रिपॉज़िटरी की सभी स्थानीय फ़ाइलें हट जाएँगी। यह पूर्ववत नहीं किया जा सकता।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ezzel az összes helyi fájl törlődik ebből a tárolóból. Ez nem vonható vissza."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Semua file lokal untuk repositori ini akan dihapus. Tindakan ini tidak dapat dibatalkan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti i file locali di questo repository verranno eliminati. Questa azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このリポジトリのローカルファイルがすべて削除されます。この操作は取り消せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 저장소의 모든 로컬 파일이 삭제됩니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette sletter alle lokale filer for dette repositoriet. Dette kan ikke angres."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle lokale bestanden van deze repository worden verwijderd. Dit kan niet ongedaan worden gemaakt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to usunięcie wszystkich lokalnych plików tego repozytorium. Tej operacji nie można cofnąć."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos os arquivos locais deste repositório serão excluídos. Esta ação não pode ser desfeita."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все локальные файлы этого репозитория будут удалены. Это действие нельзя отменить."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Alla lokala filer för detta förråd kommer att raderas. Detta kan inte ångras."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะลบไฟล์ในเครื่องทั้งหมดของ repository นี้ ไม่สามารถยกเลิกได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu depoya ait tüm yerel dosyalar silinecek. Bu işlem geri alınamaz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Усі локальні файли цього репозиторію буде видалено. Цю дію неможливо скасувати."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ xóa tất cả tệp cục bộ của kho lưu trữ này. Không thể hoàn tác."
          }
        },
        "zh-Hans": {
          "stringUnit": {
