default_platform(:ios)

platform :ios do
  release_notes_text = "• Added a one-time unlock for unlimited repositories\n• Added Send Feedback and Report a Bug actions in Settings\n• Improved clone setup by prefilling your GitHub email when available\n• Better validation when required clone fields are missing"
  app_version = "1.6"

  submission_information = {
    add_id_info_uses_idfa: false,
    export_compliance_uses_encryption: false
  }

  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV.fetch("ASC_KEY_FILEPATH"),
      duration: 1190,
      in_house: false
    )
  end

  private_lane :deliver_options do |options|
    {
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      submit_for_review: true,
      automatic_release: false,
      app_version: app_version,
      release_notes: {
        "en-US" => release_notes_text
      },
      precheck_include_in_app_purchases: false,
      submission_information: submission_information
    }.merge(options || {})
  end

  lane :release do
    build_app(
      project: "Sync.md.xcodeproj",
      scheme: "Sync.md",
      export_method: "app-store",
      export_options: {
        teamID: "67KC823C9A",
        signingStyle: "automatic",
        uploadSymbols: true
      }
    )

    asc_api_key
    upload_to_app_store(deliver_options)
  end

  lane :upload_only do
    asc_api_key
    upload_to_app_store(deliver_options(ipa: "Sync.md.ipa"))
  end

  lane :submit_only do
    asc_api_key
    upload_to_app_store(deliver_options(skip_binary_upload: true))
  end
end
