    "This will sign you out of GitHub. Your local repositories will be kept.": {
      "comment": "Sign-out confirmation dialog message",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will sign you out of GitHub. Your local repositories will be kept."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم تسجيل خروجك من GitHub. ستبقى مستودعاتك المحلية محفوظة."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette logger dig ud af GitHub. Dine lokale repositories beholdes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du wirst von GitHub abgemeldet. Deine lokalen Repositories bleiben erhalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se cerrará tu sesión de GitHub. Tus repositorios locales se conservarán."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä kirjaa sinut ulos GitHub-palvelusta. Paikalliset tietovarastosi säilytetään."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous serez déconnecté de GitHub. Vos dépôts locaux seront conservés."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "פעולה זו תנתק אותך מ-GitHub. המאגרים המקומיים שלך יישמרו."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह आपको GitHub से साइन आउट कर देगा। आपकी स्थानीय रिपॉज़िटरीज़ सुरक्षित रहेंगी।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ezzel kijelentkezel a GitHub-ból. A helyi tárolóid megmaradnak."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda akan keluar dari GitHub. Repositori lokal Anda akan tetap disimpan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verrai disconnesso da GitHub. I tuoi repository locali saranno conservati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub からサインアウトします。ローカルのリポジトリは保持されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub에서 로그아웃됩니다. 로컬 저장소는 유지됩니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette logger deg ut av GitHub. Dine lokale repositorier beholdes."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je wordt uitgelogd bij GitHub. Je lokale repository's blijven bewaard."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to wylogowanie z GitHub. Lokalne repozytoria zostaną zachowane."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você será desconectado do GitHub. Seus repositórios locais serão mantidos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы будете отключены от GitHub. Ваши локальные репозитории сохранятся."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du loggas ut från GitHub. Dina lokala förråd behålls."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะออกจากระบบ GitHub ของคุณ Repository ในเครื่องจะยังคงอยู่"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub oturumunuz kapatılacak. Yerel depolarınız korunacak."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви вийдете з GitHub. Ваші локальні репозиторії збережуться."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn sẽ được đăng xuất khỏi GitHub. Các kho lưu trữ cục bộ sẽ được giữ lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将退出你的 GitHub 账户。本地仓库将被保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將會登出您的 GitHub 帳號。您的本機儲存庫將會保留。"
          }
        }
      }
    },
