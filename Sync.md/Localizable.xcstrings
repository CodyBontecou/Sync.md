    "This repository hasn’t been cloned yet.\nTap below to download it.": {
      "comment": "Subtitle shown when a repository has not been cloned yet",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This repository hasn’t been cloned yet.\nTap below to download it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este repositorio aún no se ha clonado.\nToca abajo para descargarlo."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Repositori ini belum di-clone.\nKetuk di bawah untuk mengunduhnya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo repository non è ancora stato clonato.\nTocca sotto per scaricarlo."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 저장소는 아직 복제되지 않았습니다.\n아래를 탭하여 다운로드하십시오."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Repository นี้ยังไม่ได้โคลน\nแตะด้านล่างเพื่อดาวน์โหลด"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم استنساخ هذا المستودع بعد.\nانقر أدناه لتنزيله."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce dépôt n'a pas encore été cloné.\nTouchez ci-dessous pour le télécharger."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מאגר זה טרם שוכפל.\nהקש למטה כדי להוריד אותו."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह रिपॉज़िटरी अभी क्लोन नहीं हुई है।\nडाउनलोड करने के लिए नीचे टैप करें।"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette repositoriet er ikke klonet ennå.\nTrykk nedenfor for å laste det ned."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze repository is nog niet gekloond.\nTik hieronder om te downloaden."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este repositório ainda não foi clonado.\nToque abaixo para baixá-lo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu depo henüz klonlanmadı.\nİndirmek için aşağıya dokun."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kho lưu trữ này chưa được sao chép.\nChạm bên dưới để tải về."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该仓库尚未克隆。\n点击下方按钮进行下载。"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette repository er ikke klonet endnu.\nTryk nedenfor for at hente det."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Repository wurde noch nicht geklont.\nTippe unten, um es herunterzuladen."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tätä tietovarastoa ei ole vielä kloonattu.\nLataa se napauttamalla alla."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez a tároló még nincs klónozva.\nKoppints alább a letöltéséhez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このリポジトリはまだクローンされていません。\n下のボタンをタップしてダウンロードしてください。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To repozytorium nie zostało jeszcze sklonowane.\nStuknij poniżej, aby je pobrać."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Этот репозиторий ещё не клонирован.\nНажмите ниже, чтобы загрузить его."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det här förrådet har inte klonats ännu.\nTryck nedan för att ladda ner det."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Цей репозиторій ще не клоновано.\nНатисніть нижче, щоб завантажити його."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此儲存庫尚未複製。\n點按下方以下載。"
          }
        }
      }
    },
