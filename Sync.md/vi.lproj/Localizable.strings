"Push complete!" = "Push ho\u00e0n t\u1ea5t!";

/* Sync progress message while fetching the user's GitHub profile after sign-in */
"Fetching profile..." = "\u0110ang l\u1ea5y th\u00f4ng tin h\u1ed3 s\u01a1...";

/* Error message when PAT sign-in fails. %@ is the underlying error description. */
"Invalid token: %@" = "Token kh\u00f4ng h\u1ee3p l\u1ec7: %@";

/* Error when a stored security-scoped bookmark can no longer be resolved */
"Could not resolve folder bookmark." = "Kh\u00f4ng th\u1ec3 ph\u00e2n gi\u1ea3i bookmark th\u01b0 m\u1ee5c.";

/* Error when adding a local repo whose folder has no .git directory */
"No .git directory found. Please select a folder that contains a git repository." = "Kh\u00f4ng t\u00ecm th\u1ea5y th\u01b0 m\u1ee5c .git. Vui l\u00f2ng ch\u1ecdn th\u01b0 m\u1ee5c ch\u1ee9a kho Git.";

/* Error when reading git metadata from a local repository fails. %@ is the error detail. */
"Failed to read repository info: %@" = "Kh\u00f4ng th\u1ec3 \u0111\u1ecdc th\u00f4ng tin kho l\u01b0u tr\u1eef: %@";

/* Default commit message used when the user does not provide one */
"Update from Sync.md" = "C\u1eadp nh\u1eadt t\u1eeb Sync.md";

/* Error when a git operation is attempted on a repository that has not been cloned */
"Repository not cloned yet. Clone it first." = "Kho l\u01b0u tr\u1eef ch\u01b0a \u0111\u01b0\u1ee3c sao ch\u00e9p. H\u00e3y sao ch\u00e9p tr\u01b0\u1edbc.";

/* Error when the repository's remote URL is malformed or missing */
"Invalid remote URL." = "URL t\u1eeb xa kh\u00f4ng h\u1ee3p l\u1ec7.";

/* Error when cloning a repository fails. %@ is the libgit2 error detail. */
"Clone failed: %@" = "Sao ch\u00e9p th\u1ea5t b\u1ea1i: %@";

/* Error when fetching remote changes fails. %@ is the libgit2 error detail. */
"Fetch failed: %@" = "L\u1ea5y d\u1eef li\u1ec7u th\u1ea5t b\u1ea1i: %@";

/* Error when pushing commits fails. %@ is the libgit2 error detail. */
"Push failed: %@" = "Push th\u1ea5t b\u1ea1i: %@";

/* Error when creating a commit fails. %@ is the libgit2 error detail. */
"Commit failed: %@" = "Commit th\u1ea5t b\u1ea1i: %@";

/* Error when attempting to commit but the working tree is clean */
"No changes to commit." = "Kh\u00f4ng c\u00f3 thay \u0111\u1ed5i \u0111\u1ec3 commit.";

/* Error when the local git repository is in a corrupted state. %@ is the detail. */
"Repository corrupted: %@. Try removing and re-cloning." = "Kho l\u01b0u tr\u1eef b\u1ecb h\u1ecfng: %@. H\u00e3y x\u00f3a v\u00e0 sao ch\u00e9p l\u1ea1i.";

/* Generic libgit2 error wrapper. %@ is the libgit2 error message. */
"Git error: %@" = "L\u1ed7i Git: %@";
