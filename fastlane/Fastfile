default_platform(:ios)

platform :ios do
  release_notes_text = "• Previously cloned repositories now appear on the main screen — tap any to re-clone instantly\n• Free repository slot is now reliably preserved across reinstalls\n• Bug fixes and performance improvements"
  app_version = "1.9.2"

  submission_information = {
    add_id_info_uses_idfa: false,
    export_compliance_uses_encryption: false
  }

  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV.fetch("ASC_KEY_FILEPATH"),
      duration: 1190,
      in_house: false
    )
  end

  lane :upload_all do
    asc_api_key
    upload_to_app_store(
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      submit_for_review: false,
      automatic_release: false,
      app_version: app_version,
      release_notes: {
        "en-US" => release_notes_text
      },
      precheck_include_in_app_purchases: false,
      submission_information: submission_information,
      overwrite_screenshots: true
    )
  end

  lane :release do
    build_app(
      project: "Sync.md.xcodeproj",
      scheme: "Sync.md",
      export_method: "app-store",
      export_options: {
        teamID: "67KC823C9A",
        signingStyle: "automatic",
        uploadSymbols: true
      }
    )
    asc_api_key
    upload_to_app_store(
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      submit_for_review: true,
      automatic_release: false,
      app_version: app_version,
      release_notes: {
        "en-US" => release_notes_text
      },
      precheck_include_in_app_purchases: false,
      submission_information: submission_information,
      overwrite_screenshots: true
    )
  end
end
