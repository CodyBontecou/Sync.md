    "New repositories will be saved to the app’s default location instead.": {
      "comment": "Alert message explaining what happens after removing the custom default location",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "New repositories will be saved to the app’s default location instead."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 저장소는 앱의 기본 위치에 저장됩니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los nuevos repositorios se guardarán en la ubicación predeterminada de la app."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Repositori baru akan disimpan di lokasi default aplikasi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I nuovi repository verranno salvati nella posizione predefinita dell'app."
          }
        },
        "th": {
          "stringUnit": {
