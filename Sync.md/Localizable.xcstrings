    "Choose where new repositories\nare saved on your device": {
      "comment": "Subtitle for the default save location onboarding step",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose where new repositories\nare saved on your device"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر مكان حفظ المستودعات\nالجديدة على جهازك"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaelg hvor nye repositories\ngemmes paa din enhed"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle, wo neue Repositories\nauf deinem Gerät gespeichert werden"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige dónde se guardan los nuevos\nrepositorios en tu dispositivo"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse mihin uudet tietovarastot\ntallennetaan laitteellasi"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez où les nouveaux dépôts\nsont enregistrés sur votre appareil"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בחר היכן מאגרים חדשים\nיישמרו במכשיר שלך"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुनें कि नई रिपॉज़िटरीज़ आपके\nडिवाइस पर कहाँ सहेजी जाएँ"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válaszd ki, hová mentődjenek\naz új tárolók az eszközödön"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih tempat repositori baru\ndisimpan di perangkat Anda"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli dove salvare i nuovi\nrepository sul tuo dispositivo"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しいリポジトリの\n保存先を選択してください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 저장소가 기기에\n저장될 위치를 선택하십시오"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg hvor nye repositorier\nlagres på enheten din"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies waar nieuwe repository's\nop je apparaat worden opgeslagen"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz, gdzie nowe repozytoria\nbędą zapisywane na urządzeniu"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha onde novos repositórios\nserão salvos no seu dispositivo"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите, куда сохранять\nновые репозитории на устройстве"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj var nya förråd\nsparas på din enhet"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกตำแหน่งที่จะบันทึก\nrepository ใหม่บนอุปกรณ์ของคุณ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni depoların cihazınızda\nnereye kaydedileceğini seçin"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Оберіть, куди зберігатимуться нові\nрепозиторії на вашому пристрої"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn nơi lưu kho lưu trữ mới\ntrên thiết bị của bạn"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择新仓库在设备上的\n保存位置"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇新儲存庫在裝置上\n的儲存位置"
          }
        }
      }
    },
    "Without a default, repos save to\nFiles › On My iPhone › Sync.md": {
      "comment": "Info hint shown when no default save location is chosen during onboarding",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Without a default, repos save to\nFiles › On My iPhone › Sync.md"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بدون موقع افتراضي، تُحفظ المستودعات في\nالملفات › على iPhone › Sync.md"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Uden en standard gemmes repos i\nFiler › Paa min iPhone › Sync.md"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ohne Vorgabe werden Repos gespeichert unter\nDateien › Auf meinem iPhone › Sync.md"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin una ubicación predeterminada, los repositorios se guardan en\nArchivos › En mi iPhone › Sync.md"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ilman oletussijaintia tietovarastot tallennetaan kohteeseen\nTiedostot › iPhonessa › Sync.md"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sans emplacement par défaut, les dépôts sont enregistrés dans\nFichiers › Sur mon iPhone › Sync.md"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ללא ברירת מחדל, מאגרים יישמרו ב-\nקבצים › ב-iPhone שלי › Sync.md"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिफ़ॉल्ट के बिना, रिपो यहाँ सहेजे जाते हैं\nFiles › On My iPhone › Sync.md"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Alapértelmezés nélkül a tárolók ide mentődnek:\nFájlok › Az iPhone-omon › Sync.md"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tanpa lokasi default, repositori disimpan di\nFile › Di iPhone Saya › Sync.md"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Senza un'impostazione predefinita, i repository vengono salvati in\nFile › Sul mio iPhone › Sync.md"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デフォルトが未設定の場合、リポジトリは\nファイル › このiPhone内 › Sync.md に保存されます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본 위치를 설정하지 않으면\n파일 › 나의 iPhone › Sync.md에 저장됩니다"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Uten en standard lagres repoer i\nFiler › På min iPhone › Sync.md"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zonder standaardlocatie worden repo's opgeslagen in\nBestanden › Op mijn iPhone › Sync.md"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bez ustawienia domyślnego repozytoria zapisują się w\nPliki › Na moim iPhonie › Sync.md"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem um local padrão, os repositórios serão salvos em\nArquivos › No Meu iPhone › Sync.md"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Без настройки репозитории сохраняются в\nФайлы › На iPhone › Sync.md"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Utan standardval sparas förråd i\nFiler › På min iPhone › Sync.md"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หากไม่ได้ตั้งค่า repository จะบันทึกที่\nไฟล์ › บน iPhone ของฉัน › Sync.md"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Varsayılan belirlenmezse depolar şu konuma kaydedilir:\nDosyalar › iPhone'umda › Sync.md"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Без налаштування репозиторії зберігатимуться в\nФайли › На моєму iPhone › Sync.md"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如未设置默认位置，仓库将保存到\n文件 › 我的 iPhone › Sync.md"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "若未設定預設位置，儲存庫將儲存至\n檔案 › 我的 iPhone › Sync.md"
