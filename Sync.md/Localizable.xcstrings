    "Legacy paid user — restored from previous purchase": {
      "comment": "Subtitle for legacy users who paid before the IAP system was introduced",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Legacy paid user — restored from previous purchase"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
