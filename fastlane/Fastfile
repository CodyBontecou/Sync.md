default_platform(:ios)

platform :ios do
  release_notes_text = "• Polished toolbar UI — xmark icon replaces CANCEL text on sheet close buttons\n• Repo list rows now have full-width tap targets for easier interaction\n• Subtle subtitle text styling in action rows for better visual hierarchy"
  app_version = "2.0.0"

  submission_information = {
    add_id_info_uses_idfa: false,
    export_compliance_uses_encryption: false
  }

  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV.fetch("ASC_KEY_FILEPATH"),
      duration: 1190,
      in_house: false
    )
  end

  lane :upload_metadata do
    asc_api_key
    upload_to_app_store(
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      submit_for_review: false,
      automatic_release: false,
      app_version: app_version,
      release_notes: {
        "en-US" => release_notes_text
      },
      precheck_include_in_app_purchases: false,
      submission_information: submission_information
    )
  end

  lane :upload_screenshots do
    asc_api_key
    upload_to_app_store(
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: true,
      force: true,
      submit_for_review: false,
      automatic_release: false,
      app_version: app_version,
      precheck_include_in_app_purchases: false,
      overwrite_screenshots: false,
      sync_screenshots: true
    )
  end

  lane :upload_all do
    asc_api_key
    upload_to_app_store(
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      submit_for_review: false,
      automatic_release: false,
      app_version: app_version,
      release_notes: {
        "en-US" => release_notes_text
      },
      precheck_include_in_app_purchases: false,
      submission_information: submission_information,
      overwrite_screenshots: true
    )
  end

  lane :submit do
    asc_api_key
    upload_to_app_store(
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      submit_for_review: true,
      automatic_release: false,
      app_version: app_version,
      release_notes: {
        "en-US" => release_notes_text
      },
      precheck_include_in_app_purchases: false,
      submission_information: submission_information
    )
  end

  lane :release do
    build_app(
      project: "Sync.md.xcodeproj",
      scheme: "Sync.md",
      export_method: "app-store",
      export_options: {
        teamID: "67KC823C9A",
        signingStyle: "automatic",
        uploadSymbols: true
      }
    )
    asc_api_key
    upload_to_app_store(
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      submit_for_review: true,
      automatic_release: false,
      app_version: app_version,
      release_notes: {
        "en-US" => release_notes_text
      },
      precheck_include_in_app_purchases: false,
      submission_information: submission_information,
      overwrite_screenshots: true
    )
  end
end
