        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les nouveaux dépôts seront enregistrés à l'emplacement par défaut de l'app."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מאגרים חדשים יישמרו במיקום ברירת המחדל של האפליקציה במקום."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नई रिपॉज़िटरीज़ इसके बजाय ऐप के डिफ़ॉल्ट स्थान पर सहेजी जाएँगी।"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Nye repositorier lagres på appens standardplassering i stedet."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nieuwe repository's worden in plaats daarvan opgeslagen op de standaardlocatie van de app."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Novos repositórios serão salvos no local padrão do app."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni depolar bunun yerine uygulamanın varsayılan konumuna kaydedilecek."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kho lưu trữ mới sẽ được lưu vào vị trí mặc định của ứng dụng."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新仓库将改为保存到应用的默认位置。"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Nye repositories gemmes i stedet paa appens standardplacering."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Neue Repositories werden stattdessen am Standard-Speicherort der App gesichert."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
